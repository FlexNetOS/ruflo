{
  "_comment_skillListingBudgetFraction": "#1834 — repo has 367 SKILL.md files (5x duplicates of common skills) across .agents/skills, .claude/skills, archive/v2/.claude/skills, v3/@claude-flow/{cli,mcp}/.claude/skills. With Claude Code's default 1% budget, ~378 descriptions get truncated. Bumping to 6% covers the actual usage (5.5%). Long-term fix is to prune the duplicates and archive paths (see #1834).",
  "agents": {
    "customAgents": [],
    "source": ".claude/agents"
  },
  "attribution": {
    "commit": "Co-Authored-By: RuFlo <ruv@ruv.net>",
    "pr": "🤖 Generated with [RuFlo](https://github.com/ruvnet/ruflo)"
  },
  "claudeFlow": {
    "adr": {
      "autoGenerate": true,
      "directory": "/docs/adr",
      "template": "madr"
    },
    "agentTeams": {
      "coordination": {
        "autoAssignOnIdle": true,
        "notifyLeadOnComplete": true,
        "sharedMemoryNamespace": "agent-teams",
        "trainPatternsOnComplete": true
      },
      "enabled": true,
      "hooks": {
        "taskCompleted": {
          "enabled": true,
          "notifyLead": true,
          "trainPatterns": true
        },
        "teammateIdle": {
          "autoAssign": true,
          "checkTaskList": true,
          "enabled": true
        }
      },
      "mailboxEnabled": true,
      "taskListEnabled": true,
      "teammateMode": "auto"
    },
    "daemon": {
      "autoStart": true,
      "schedules": {
        "audit": {
          "interval": "1h",
          "priority": "critical"
        },
        "consolidate": {
          "interval": "2h",
          "priority": "low"
        },
        "deepdive": {
          "interval": "4h",
          "priority": "normal"
        },
        "document": {
          "interval": "1h",
          "priority": "normal"
        },
        "optimize": {
          "interval": "30m",
          "priority": "high"
        },
        "ultralearn": {
          "interval": "1h",
          "priority": "normal"
        }
      },
      "workers": [
        "map",
        "audit",
        "optimize",
        "consolidate",
        "testgaps",
        "ultralearn",
        "deepdive",
        "document",
        "refactor",
        "benchmark"
      ]
    },
    "ddd": {
      "directory": "/docs/ddd",
      "trackDomains": true,
      "validateBoundedContexts": true
    },
    "enabled": true,
    "learning": {
      "autoTrain": true,
      "enabled": true,
      "patterns": [
        "coordination",
        "optimization",
        "prediction"
      ],
      "retention": {
        "longTerm": "30d",
        "shortTerm": "24h"
      }
    },
    "memory": {
      "agentScopes": {
        "enabled": true
      },
      "backend": "hybrid",
      "enableHNSW": true,
      "learningBridge": {
        "enabled": true
      },
      "memoryGraph": {
        "enabled": true
      }
    },
    "modelPreferences": {
      "default": "claude-opus-4-7",
      "routing": "claude-haiku-4-5-20251001"
    },
    "neural": {
      "enabled": true
    },
    "security": {
      "autoScan": true,
      "cveCheck": true,
      "scanOnEdit": true,
      "threatModel": true
    },
    "swarm": {
      "maxAgents": 15,
      "topology": "hierarchical-mesh"
    },
    "version": "3.6.11"
  },
  "customInstructions": "Follow the project's CLAUDE.md guidelines. Use concurrent execution for all operations. Prioritize v3 implementation with security-first development, 15-agent swarm coordination, phased performance optimization, and cross-platform helper automation.",
  "enabledMcpjsonServers": [
    "claude-flow"
  ],
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_FLOW_HOOKS_ENABLED": "true",
    "CLAUDE_FLOW_V3_ENABLED": "true"
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" post-edit",
            "timeout": 10000,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" compact-manual",
            "type": "command"
          },
          {
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" session-end",
            "timeout": 5000,
            "type": "command"
          }
        ],
        "matcher": "manual"
      },
      {
        "hooks": [
          {
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" compact-auto",
            "type": "command"
          },
          {
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" session-end",
            "timeout": 6000,
            "type": "command"
          }
        ],
        "matcher": "auto"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" pre-bash",
            "timeout": 5000,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" session-end",
            "timeout": 10000,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" session-restore",
            "timeout": 15000,
            "type": "command"
          },
          {
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/auto-memory-hook.mjs\" import",
            "timeout": 8000,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "sh -lc 'root=\"$(git rev-parse --show-toplevel)\"; exec rusty-idd next --base \"$root\"'",
            "statusMessage": "Rusty IDD front door: computing the next step",
            "timeout": 180,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/auto-memory-hook.mjs\" sync",
            "timeout": 10000,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" post-task",
            "timeout": 5000,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/helpers/hook-handler.cjs\" route",
            "timeout": 10000,
            "type": "command"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "claude-flow": {
      "args": [
        "-y",
        "ruflo@latest",
        "mcp",
        "start"
      ],
      "command": "npx"
    }
  },
  "model": "claude-opus-4-7",
